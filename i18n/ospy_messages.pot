#: ospy/options.py:345
msgid "Master start offset"
msgstr ""

#: ospy/options.py:347
msgid "Time offset for starting master station 1 relative to the station start, in seconds between -1800 and +1800. Negative values start the master earlier; positive values start it later. Example: -10 starts the master 10 seconds before the station, +10 starts it 10 seconds after the station."
msgstr ""

#: ospy/options.py:354
msgid "Master stop offset"
msgstr ""

#: ospy/options.py:356
msgid "Time offset for stopping master station 1 relative to the station end, in seconds between -1800 and +1800. Negative values stop the master earlier; positive values keep it running longer. Example: -5 stops the master 5 seconds before the station ends, +20 stops it 20 seconds after the station ends."
msgstr ""

#: ospy/options.py:363
msgid "Master two start offset"
msgstr ""

#: ospy/options.py:365
msgid "Time offset for starting master station 2 relative to the station start, in seconds between -1800 and +1800. Negative values start the master earlier; positive values start it later. Example: -10 starts master 2 10 seconds before the station, +10 starts it 10 seconds after the station."
msgstr ""

#: ospy/options.py:372
msgid "Master two stop offset"
msgstr ""

#: ospy/options.py:374
msgid "Time offset for stopping master station 2 relative to the station end, in seconds between -1800 and +1800. Negative values stop the master earlier; positive values keep it running longer. Example: -5 stops master 2 5 seconds before the station ends, +20 stops it 20 seconds after the station ends."
msgstr ""

