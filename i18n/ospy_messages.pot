#: ospy/options.py:318
msgid "Pause between stations"
msgstr ""

#: ospy/options.py:320
msgid "Pause inserted between sequential station runs when the scheduler cannot run them at the same time, in seconds between 0 and 3600. This does not shift a station against the master station. Example: with maximum usage 1 and station usage 1, value 30 starts the next station 30 seconds after the previous station ends."
msgstr ""

#: ospy/options.py:327
msgid "Minimum runtime"
msgstr ""

#: ospy/options.py:329
msgid "Skip the pause between stations when the previous run was shorter than this value, in seconds between 0 and 86400. Example: with pause 30 and minimum runtime 10, a station that ran only 5 seconds will not force the 30 second pause."
msgstr ""

