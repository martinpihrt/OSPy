#: plugins/lcd_display/templates/lcd_display_help.html:48
msgid "Sensors"
msgstr "Snímače"

#: ospy/options.py:262
msgid "Sensor HTTP timeout"
msgstr "HTTP timeout pro snímače"

#: ospy/options.py:264
msgid "Timeout in seconds for HTTP requests sent from OSPy to sensors."
msgstr ""
"Timeout za několik sekund pro HTTP požadavky odesílané z OSPy na senzory."

#: ospy/options.py:273
msgid "Maximum usage"
msgstr "Maximální využití"

#: ospy/options.py:275
msgid ""
"Determines how station runs are combined. 0 means no limit. 1 means one "
"station at a time when each station has usage 1. This also affects when the "
"pause between stations is inserted."
msgstr ""
"Určuje, jak se kombinují běhy stanic. 0 znamená bez omezení. 1 znamená vždy "
"jednu stanici najednou, pokud má každá stanice využití 1. Toto nastavení "
"také ovlivňuje, kdy se vloží pauza mezi stanicemi."

#: ospy/options.py:276 ospy/options.py:283 ospy/options.py:292
#: ospy/options.py:301
msgid "Station Handling"
msgstr "Nastavení stanic"

#: ospy/options.py:280
msgid "Number of outputs"
msgstr "Počet výstupů"

#: ospy/options.py:282
msgid "The number of outputs available (8 + 8*extensions)"
msgstr "Celkový počet výstupů k dispozici je (8 výstupů + x rozšíření.)"

#: ospy/options.py:289
msgid "Pause between stations"
msgstr "Pauza mezi stanicemi"

#: ospy/options.py:291
msgid ""
"Pause inserted between sequential station runs when the scheduler cannot run "
"them at the same time, in seconds between 0 and 3600. This does not shift a "
"station against the master station. Example: with maximum usage 1 and "
"station usage 1, value 30 starts the next station 30 seconds after the "
"previous station ends."
msgstr ""
"Pauza vložení mezi postupné spouštěné stanice, když je plánovač nemůže "
"spustit současně, v sekundách mezi 0 a 3600. Toto neposouvá stanici vůči "
"hlavní stanici. Příklad: při maximálním využití 1 a využití stanice 1 "
"hodnota 30 spustí další stanici 30 sekund po skončení předchozí stanice."

#: ospy/options.py:298
msgid "Minimum runtime"
msgstr "Min čas běhu"

#: ospy/options.py:300
msgid ""
"Skip the pause between stations when the previous run was shorter than this "
"value, in seconds between 0 and 86400. Example: with pause 30 and minimum "
"runtime 10, a station that ran only 5 seconds will not force the 30 second "
"pause."
msgstr ""
"Přeskočit pauzu mezi stanicemi, pokud byl předchozí běh kratší než tato "
"hodnota, v sekundách mezi 0 a 86400. Příklad: při pauze 30 a minimální době "
"běhu stanice 10 a ta běžela pouze 5 sekund, nevynutí 30 sekundovou pauzu."

#: ospy/options.py:309
msgid "Activate relay"
msgstr "Aktivovat relé"

#: ospy/options.py:311
msgid "Also activate the relay as master output."
msgstr "Aktivovat také relé jako hlavní výstup."

#: ospy/options.py:312 ospy/options.py:319 ospy/options.py:328
#: ospy/options.py:337 ospy/options.py:346
msgid "Configure Master"
msgstr "Nastavení hl. stanice"

#: ospy/options.py:316
msgid "Master start offset"
msgstr "Posun startu hlavní stanice"

#: ospy/options.py:318
msgid ""
"Time offset for starting master station 1 relative to the station start, in "
"seconds between -1800 and +1800. Negative values start the master earlier; "
"positive values start it later. Example: -10 starts the master 10 seconds "
"before the station, +10 starts it 10 seconds after the station."
msgstr ""
"Časový posun zapnutí hlavní stanice 1 vůči startu stanice, v sekundách "
"mezi-1800 a +1800. Záporné hodnoty spustí hlavní stanici dříve, kladné "
"hodnoty později. Příklad: -10 spustí hlavní stanici 10 sekund před stanicí, "
"+10 ji spustí 10 sekund po stanici."

#: ospy/options.py:325
msgid "Master stop offset"
msgstr "Posun vypnutí hlavní stanice"

#: ospy/options.py:327
msgid ""
"Time offset for stopping master station 1 relative to the station end, in "
"seconds between -1800 and +1800. Negative values stop the master earlier; "
"positive values keep it running longer. Example: -5 stops the master 5 "
"seconds before the station ends, +20 stops it 20 seconds after the station "
"ends."
msgstr ""
"Časový posun vypnutí hlavní stanice 1 vůči konci stanice, v sekundách "
"mezi-1800 a +1800. Záporné hodnoty vypnou hlavní stanici dříve, kladné "
"hodnoty ji nechají běžet déle. Příklad: -5 vypne hlavní stanici 5 sekund "
"před koncem stanice, +20 ji vypne 20 sekund po konci stanice."

#: ospy/options.py:334
msgid "Master two start offset"
msgstr "Posun startu hlavní stanice 2"

#: ospy/options.py:336
msgid ""
"Time offset for starting master station 2 relative to the station start, in "
"seconds between -1800 and +1800. Negative values start the master earlier; "
"positive values start it later. Example: -10 starts master 2 10 seconds "
"before the station, +10 starts it 10 seconds after the station."
msgstr ""
"Časový posun zapnutí hlavní stanice 2 vůči startu stanice, v sekundách "
"mezi-1800 a +1800. Záporné hodnoty spustí hlavní stanici dříve, kladné "
"hodnoty později. Příklad: -10 spustí hlavní stanici 10 sekund před stanicí, "
"+10 ji spustí 10 sekund po stanici."

#: ospy/options.py:343
msgid "Master two stop offset"
msgstr "Posun vypnutí hlavní stanice 2"

#: ospy/options.py:345
msgid ""
"Time offset for stopping master station 2 relative to the station end, in "
"seconds between -1800 and +1800. Negative values stop the master earlier; "
"positive values keep it running longer. Example: -5 stops master 2 5 seconds "
"before the station ends, +20 stops it 20 seconds after the station ends."
msgstr ""
"Časový posun vypnutí hlavní stanice 2 vůči konci stanice, v sekundách "
"mezi-1800 a +1800. Záporné hodnoty vypnou hlavní stanici dříve, kladné "
"hodnoty ji nechají běžet déle. Příklad: -5 vypne hlavní stanici 5 sekund "
"před koncem stanice, +20 ji vypne 20 sekund po konci stanice."

