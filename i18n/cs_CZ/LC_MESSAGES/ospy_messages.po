#: ospy/options.py:69
msgid "Show plugins on home"
msgstr "Zobrazit rozšíření na home"

#: ospy/options.py:71
msgid "Show data from plugins on home page."
msgstr "Zobrazit data z rozšíření na domovské stránce."

#: ospy/options.py:76
msgid "Show sensors on home"
msgstr "Zobrazit snímače na home"

#: ospy/options.py:78
msgid "Show data from sensors on home page."
msgstr "Zobrazit data ze snímačů na domovské stránce."

#: ospy/options.py:83
msgid "Show pictures at stations"
msgstr "Zobrazit obrázky na stanicích"

#: ospy/options.py:85
msgid "Show pictures of stations on the homepage."
msgstr "Zobrazit obrázky stanic na domovské stránce."

#: ospy/options.py:90
msgid "Station picture source"
msgstr "Zdroj obrazků u stanic"

#: ospy/options.py:93
msgid ""
"Choose whether station pictures on the home page use uploaded station images "
"or cached images from the IP Cam plug-in. This is used only when station "
"pictures are enabled."
msgstr ""
"Zvolte, zda obrázky stanic na domovské stránce používají nahrané obrázky "
"stanic nebo cachované obrázky z IP Cam plug-inu. Používá se pouze při "
"zapnutí obrázků u stanic."

#: ospy/options.py:98
msgid "Show icons instead of text"
msgstr "Zobrazení ikon místo textu"

#: ospy/options.py:100
msgid "When activated, in header menu will display icons instead of text."
msgstr ""
"Pokud je aktivováno, v nabídce záhlaví OSPy se místo textu zobrazí ikony."

#: ospy/options.py:105
msgid "Show back to top button"
msgstr "Tlačítko zpátky nahoru"

#: ospy/options.py:107
msgid ""
"Show a button for scrolling back to the top of the page after the page is "
"scrolled down."
msgstr ""
"Zobrazit tlačítko pro posun zpět na začátek stránky poté, co se stránka "
"posune dolů."

#: ospy/options.py:112
msgid "Back to top position"
msgstr "Zpět nahoru pozice"

#: ospy/options.py:115
msgid ""
"Choose whether the back to top button is shown at the bottom left or bottom "
"right of the page."
msgstr ""
"Zvolit, zda se tlačítko zpět nahoru zobrazí vlevo dole nebo vpravo dole na "
"stránce."

#: ospy/options.py:120
msgid "Enabled plug-ins"
msgstr "Povolit rozšíření"

#: ospy/options.py:125
msgid "Plug-in status"
msgstr "Stav rozšíření"

#: ospy/options.py:130
msgid "Automatic plug-in updates"
msgstr "Automatická aktualizace rozšíření"

#: ospy/options.py:135
msgid "Enable plug-in check status updates"
msgstr "Povolení aktualizací pro rozšíření"

#: ospy/options.py:140
msgid "IP for DNS ping"
msgstr "IP pro ping DNS"

#: ospy/options.py:142
msgid ""
"IP address for pinging a DNS server that is outside the internal network. If "
"ping is not available, all network operations (log, user downloads, "
"certificates) are skipped."
msgstr ""
"IP adresa pro příkaz ping na server DNS, který je mimo interní síť. Pokud "
"příkaz ping není k dispozici, všechny síťové operace (logy, stahování "
"uživatelů, certifikát) budou přeskočeny."

#: ospy/options.py:156
msgid "Use Weather"
msgstr "Použít počasí"

#: ospy/options.py:158
msgid "Enabling or disabling connection to service Stormglass.io."
msgstr "Povolení nebo zakázání připojení ke službě Stormglass.io."

#: ospy/options.py:159 ospy/options.py:166 ospy/options.py:173
#: plugins/weather_based_rain_delay/__init__.py:78
msgid "Weather"
msgstr "Počasí"

#: ospy/options.py:163
msgid "Storm Glass API key"
msgstr "Klíč rozhraní API Storm Glass"

#: ospy/options.py:165
msgid ""
"To make use of local weather conditions, a Storm Glass API key is needed."
msgstr ""
"Chcete-li využít místní povětrnostní podmínky, je potřeba klíč API Storm "
"Glass."

#: ospy/options.py:170
msgid "Location"
msgstr "Umístění"

#: ospy/options.py:172
msgid ""
"City name or zip code. Used to determine location via OpenStreetMap for "
"weather information."
msgstr ""
"Název města nebo PSČ. Používá se k určení místa prostřednictvím "
"OpenStreetMap pro informace o počasí."

#: ospy/options.py:179
msgid "Disable security"
msgstr "Bez hesla"

#: ospy/options.py:181
msgid "Allow anonymous users to access the system without a password."
msgstr "Povolit anonymním uživatelům přístup do systému bez hesla."

#: ospy/options.py:182 ospy/options.py:189
msgid "Users"
msgstr "Uživatelé"

#: ospy/options.py:186
msgid "Administrator name"
msgstr "Jméno správce"

#: ospy/options.py:188
msgid "Administrator login name for login to the OSPy."
msgstr "Přihlašovací jméno správce pro přihlášení k OSPy."

#: ospy/options.py:195
msgid "Use HTTPS access"
msgstr "Použít HTTPS"

#: ospy/options.py:197
msgid ""
"Read HELP/Web Interface Guide. SSL certificate via Lets Encrypt "
"certification authority (effective after reboot.)"
msgstr ""
"Přečtěte si NÁPOVĚDU a příručku k webovému rozhraní. SSL certifikát je "
"generován prostřednictvím certifikační autority (po instalaci je nutné "
"restartování OSPy)."

#: ospy/options.py:198 ospy/options.py:205 ospy/options.py:212
#: ospy/options.py:219 ospy/options.py:226 ospy/options.py:233
#: ospy/options.py:240 ospy/options.py:247
msgid "Security"
msgstr "Bezpečnost"

#: ospy/options.py:202
msgid "Domain name"
msgstr "Jméno domény"

#: ospy/options.py:204
msgid ""
"Domain name for generating SSL certificate via Lets Encrypt certification "
"authority. Example: home.sprinkler.com"
msgstr ""
"Jméno domény, které bylo použito pro generování certifikátu SSL "
"prostřednictvím certifikační autority. Příklad: home.sprinkler.com"

#: ospy/options.py:209
msgid "Use Own HTTPS access"
msgstr "Použít vlastní HTTPS"

#: ospy/options.py:211
msgid ""
"SSL certificate via own file without certification authority (effective "
"after reboot.)"
msgstr ""
"SSL zabezpečení pomocí vlastního certifikátu bez certifikační autority (po "
"vložení souborů fullchain.pem a privkey.pem do složky ssl v umístění OSPy je "
"nutný restart OSPy.)"

#: ospy/options.py:216
msgid "API CORS allowed origin"
msgstr "API CORS povolený původ"

#: ospy/options.py:218
msgid ""
"Allowed browser origin for API CORS requests. Use * to allow any origin, "
"enter one origin such as https://example.com, enter multiple origins "
"separated by commas, or leave empty to disable CORS headers. This affects "
"browser-based API clients only."
msgstr ""
"Povolený prohlížečový původ pro požadavky API CORS. Použijte * pro povolení "
"libovolného počátku, zadání jednoho počátku například https://example.com, "
"zadání více počátků oddělených čárkami nebo ponechání prázdného pro "
"deaktivaci CORS hlaviček. To se týká pouze klientů API založených na "
"prohlížeči."

#: ospy/options.py:223
msgid "Enable API JSONP"
msgstr "Povolit API JSONP"

#: ospy/options.py:225
msgid ""
"Allow legacy API JSONP responses via the callback query parameter. Keep "
"disabled unless an old integration requires JSONP, because normal API "
"clients should use JSON with CORS instead."
msgstr ""
"Povolit starší odpovědi API JSONP prostřednictvím parametru callback dotazu. "
"Nechte to vypnuté, pokud stará integrace nevyžaduje JSONP, protože běžní API "
"klienti by měli používat JSON s CORS místo toho."

#: ospy/options.py:230
msgid "Require sensor API auth"
msgstr "Vyžadovat ověření pro API snímačů"

#: ospy/options.py:232
msgid ""
"Require HTTP Basic authentication for sensor reports sent to /api/sensor. "
"Keep disabled for older sensor firmware that cannot send credentials."
msgstr ""
"Vyžadovat HTTP Basic autentizaci pro zprávy ze snímačů odesílané do /api/"
"sensor. Nechte zapnuté pro starší firmware senzorů (pokud neposílají "
"přihlašovací údaje.)"

#: ospy/options.py:237
msgid "Require API CSRF token"
msgstr "Vžadovat API CSRF token"

#: ospy/options.py:239
msgid ""
"Require a CSRF token for state-changing API requests. Keep disabled for "
"older integrations that use only HTTP Basic authentication."
msgstr ""
"Vyžadujte CSRF token pro požadavky na změnu stavu API. U starších integrací, "
"které používají pouze HTTP Basic autentizaci, nechte vypnuté."

#: ospy/options.py:244
msgid "Maximum upload size"
msgstr "Maximální velikost uploadovaného souboru"

#: ospy/options.py:246
msgid ""
"Maximum uploaded file size in MB for backup restore, SSL files, station "
"images, and custom sensor firmware. Use 0 for no application limit."
msgstr ""
"Maximální velikost nahraného souboru v MB pro obnovu záloh, SSL soubory, "
"obrazy stanic a vlastní firmware senzorů. Použijte 0 pro neomezený limit "
"aplikací."

#: ospy/options.py:255
msgid "Password FW"
msgstr "Heslo FW"

#: ospy/options.py:257
msgid ""
"Password for uploading firmware from OSPy to sensor (for all used sensors - "
"the same password must be used in sensor options.)"
msgstr ""
"Heslo pro nahrávání firmwaru z OSPy do snímače (pro všechny použité snímače "
"- stejné heslo musí být použito i v nastavení snímače). Výchozí heslo je: "
"\"fg4s5b.s,trr7sw8sgyvrDfg\"."

#: ospy/options.py:258 ospy/options.py:265 ospy/templates/base.html:287
#: plugins/cli_control/templates/cli_control_help.html:12
#: plugins/email_notifications/__init__.py:226
