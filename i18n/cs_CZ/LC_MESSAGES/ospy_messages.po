msgstr "Zásuvný modul Relay 16: 2018-06-06 10:35:08 3 Nastavení výstupů."

#: plugins/relay_16/templates/relay_16_help.html:41
msgid ""
"Relay 16 plug-in: Possible GPIO "
"[22,24,26,32,36,38,40,21,23,29,31,33,35,37,18,19]."
msgstr ""
"Zásuvný modul Relay 16: Možné GPIO "
"[22,24,26,32,36,38,40,21,23,29,31,33,35,37,18,19]."

#: plugins/relay_16/templates/relay_16_help.html:42
msgid ""
"Relay 16 plug-in: 2018-06-06 10:35:08 Setings Relay Output 22 to HIGH "
"(Station 1 ON)."
msgstr ""
"Zásuvný modul Relay 16: 2018-06-06 10:35:08 Nastavení Relé Výstup relé 22 na "
"HIGH (stanice 1 ON)."

#: plugins/relay_16/templates/relay_16_help.html:43
msgid ""
"Relay 16 plug-in: 2018-06-06 10:35:28 Setings Relay Output 22 to LOW  "
"(Station 1 OFF)."
msgstr ""
"Zásuvný modul Relay 16: 2018-06-06 10:35:28 Nastavení Relé Výstup relé 22 až "
"NÍZKÝ (stanice 1 VYPNUTO)."

