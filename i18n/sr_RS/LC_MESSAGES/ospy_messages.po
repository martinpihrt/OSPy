msgid "Relay 16 plug-in: Possible GPIO [22,24,26,32,36,38,40,21,23,29,31,33,35,37,18,19]."
msgstr "Релеј 16 плуг-ин: могуће GPIO [22,24,26,32,36,38,40,21,23,29,31,33,35,37,18,19]."

#: plugins/relay_16/templates/relay_16_help.html:42
