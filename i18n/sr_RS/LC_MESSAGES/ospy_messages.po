msgid "RED"
msgstr "RED"

#: plugins/chmi/templates/chmi.html:345 plugins/labelmaker/templates/labelmaker.html:67
msgid "GREEN"
msgstr "GREEN"

#: plugins/chmi/templates/chmi.html:346 plugins/labelmaker/templates/labelmaker.html:68
