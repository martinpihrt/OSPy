#: plugins/tank_monitor/templates/tank_monitor_debug_log.html:15
msgid "Byte 0 and byte 1 is ping value. Value=data[0]*255 + data[1]."
msgstr "Байт 0 и байт 1 — это значение пинга. Значение=данные[0]*255 + данные[1]."

#: plugins/tank_monitor/templates/tank_monitor_debug_log.html:16
msgid "Byte 2 is firmware version in atmega 328 on sonic board hardware. Known version is 0x0D=FW1.3, 0x0E=FW1.4, 0x0F=FW1.5..."
msgstr "Байт 2 — это версия прошивки Atmega 328 на звуковой плате. Известная версия: 0x0D=FW1.3, 0x0E=FW1.4, 0x0F=FW1.5..."

#: plugins/tank_monitor/templates/tank_monitor_debug_log.html:17
msgid "Byte 3 is CRC check from board. Calculating from byte 0 and byte 1."
msgstr "Байт 3 — это CRC проверки с платы. Вычисление из байта 0 и байта 1."

