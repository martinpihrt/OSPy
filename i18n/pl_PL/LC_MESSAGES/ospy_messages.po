msgid "Example of an print from plugin"
msgstr "Przykład wydruku z wtyczki"

#: plugins/relay_16/templates/relay_16_help.html:40
msgid "Relay 16 plug-in: 2018-06-06 10:35:08 3 Outputs set."
msgstr "Wtyczka przekaźnika 16: 2018-06-06 10:35:08 3 Wyjścia ustawione."

#: plugins/relay_16/templates/relay_16_help.html:41
msgid ""
"Relay 16 plug-in: Possible GPIO "
"[22,24,26,32,36,38,40,21,23,29,31,33,35,37,18,19]."
msgstr ""
"Wtyczka przekaźnika 16: Możliwa GPIO "
"[22,24,26,32,36,38,40,21,23,29,31,33,35,37,18,19]."

#: plugins/relay_16/templates/relay_16_help.html:42
msgid ""
"Relay 16 plug-in: 2018-06-06 10:35:08 Setings Relay Output 22 to HIGH (Station "
"1 ON)."
msgstr ""
"Wtyczka przekaźnika 16: 2018-06-06 10:35:08 Ustawienia Wyjście przekaźnika 22 "
"do HIGH (Stacja 1 WŁ.)."

#: plugins/relay_16/templates/relay_16_help.html:43
msgid ""
"Relay 16 plug-in: 2018-06-06 10:35:28 Setings Relay Output 22 to LOW  (Station "
"1 OFF)."
msgstr ""
"Wtyczka przekaźnika 16: 2018-06-06 10:35:28 Ustawienia Wyjście przekaźnika 22 "
"do LOW (Stacja 1 OFF)."

