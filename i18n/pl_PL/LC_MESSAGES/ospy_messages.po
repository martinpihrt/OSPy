#: plugins/tank_monitor/templates/tank_monitor_debug_log.html:11
msgid "Warning! Logging is only done when values change."
msgstr "Uwaga! Rejestrowanie odbywa się tylko w przypadku zmiany wartości."

#: plugins/tank_monitor/templates/tank_monitor_debug_log.html:13
msgid ""
"Warning! Logging is performed every 3 seconds. The file will be large and "
"frequent saving to a file on the SD card can damage the card!"
