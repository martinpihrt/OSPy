#: plugins/remote_notifications/templates/remote_notifications.html:36
#: plugins/remote_notifications/templates/remote_notifications_help.html:16
msgid "Remote server address"
msgstr "Adres serwera zdalnego"

#: plugins/remote_notifications/templates/remote_notifications.html:38
msgid "ex: https://server.com/automatOSPy/"
msgstr "np.: https://server.com/automatOSPy/"

#: plugins/remote_notifications/templates/remote_notifications.html:42
#: plugins/remote_notifications/templates/remote_notifications_help.html:19
msgid "API for access"
msgstr "API za dostęp"

#: plugins/remote_notifications/templates/remote_notifications.html:58
msgid "Send test data to server"
msgstr "Wyślij dane testowe na serwer"

#: plugins/remote_notifications/templates/remote_notifications_help.html:3
#: plugins/remote_notifications/templates/remote_notifications_help.html:7
msgid "Remote Notifications - help"
msgstr "Zdalne powiadomienia - pomoc"

#: plugins/remote_notifications/templates/remote_notifications_help.html:8
msgid ""
"This plugin can send Notifications on the Remote Webserver. This plugin requre "
"SQL server and Webserver with PHP."
msgstr ""
"Ta wtyczka może wysyłać powiadomienia na zdalny serwer WWW. Ta wtyczka wymaga "
"serwera SQL i serwera WWW z numerem PHP."

#: plugins/remote_notifications/templates/remote_notifications_help.html:9
msgid "This plugin send data as get command to remote PHP web pages."
msgstr ""
"Ta wtyczka wysyła dane jako polecenie get do zdalnych stron internetowych PHP."

#: plugins/remote_notifications/templates/remote_notifications_help.html:10
msgid ""
"This plugin requred correct settings this plugins: UPS Monitor, Tank Humi "
"Monitor, Air Temperature and Humidity Monitor."
msgstr ""
"Ta wtyczka wymagała poprawnych ustawień tych wtyczek: Monitor UPS, Monitor "
"Humi zbiornika, Monitor temperatury i wilgotności powietrza."

#: plugins/remote_notifications/templates/remote_notifications_help.html:11
msgid ""
"If I not have a public IP address, or for some reason can not connect directly "
"to OSPy I use this plugin for display on the site, which is accessible from "
"the Internet."
msgstr ""
"Jeśli nie mam publicznego adresu IP lub z jakiegoś powodu nie mogę połączyć "
"się bezpośrednio z OSPy, używam tej wtyczki do wyświetlania na stronie, która "
"jest dostępna z Internetu."

#: plugins/remote_notifications/templates/remote_notifications_help.html:15
msgid "If checked send data to remote server is active."
msgstr "Jeśli zaznaczone, wysyłanie danych do zdalnego serwera jest aktywne."

#: plugins/remote_notifications/templates/remote_notifications_help.html:17
msgid "Type your remote server address where are the php files."
msgstr "Wpisz adres zdalnego serwera, na którym znajdują się pliki php."

#: plugins/remote_notifications/templates/remote_notifications_help.html:18
msgid "Example: https://server.com/automatOSPy/"
msgstr "Przykład: https://server.com/automatOSPy/"

#: plugins/remote_notifications/templates/remote_notifications_help.html:20
msgid "Type your API key, that is stored in a file save.php on the server."
msgstr ""
"Wpisz swój klucz API, który jest przechowywany w pliku save.php na serwerze."

#: plugins/remote_notifications/templates/remote_notifications_help.html:21
msgid "Example: msd455fsvv4sd5dv445s5s6d5vsdvdsv"
msgstr "Przykład: msd455fsvv4sd5dv445s5s6d5vsdvdsv"

#: plugins/remote_notifications/templates/remote_notifications_help.html:22
msgid " Status"
msgstr " Stan"

#: plugins/remote_notifications/templates/remote_notifications_help.html:25
msgid "for to demonstrate the function of watering my flowers."
msgstr "aby zademonstrować funkcję podlewania moich kwiatów."

#: plugins/remote_notifications/templates/remote_notifications_help.html:26
msgid ""
"Note: For this plugin we need a public web server with PHP support and access "
"to SQL database into which data is written from this plugin."
msgstr ""
"Uwaga: Do tej wtyczki potrzebny jest publiczny serwer WWW z obsługą PHP i "
"dostępem do bazy danych SQL, do której zapisywane są dane z tej wtyczki."

#: plugins/remote_notifications/templates/remote_notifications_help.html:30
msgid "download automatOSPy.zip files from github"
msgstr "pobierz pliki automatOSPy.zip z githuba"

#: plugins/remote_notifications/templates/remote_notifications_help.html:31
msgid ""
"On the SQL server we create new database with new table: ospy as in imagge"
msgstr ""
"Na serwerze SQL tworzymy nową bazę danych z nową tabelą: ospy jak na obrazku"

#: plugins/remote_notifications/templates/remote_notifications_help.html:36
msgid "In file save.php we type own API key same as use this plugin."
msgstr ""
"W pliku save.php wpisujemy własny klucz API, taki sam jak w przypadku tej "
"wtyczki."

#: plugins/remote_notifications/templates/remote_notifications_help.html:38
msgid "In file connect.php we type"
msgstr "W pliku connect.php wpisujemy"

#: plugins/remote_notifications/templates/remote_notifications_help.html:40
msgid "server=\"address SQL server\""
msgstr "serwer=\"adres serwera SQL\""

#: plugins/remote_notifications/templates/remote_notifications_help.html:41
msgid "user=\"user name SQL server\""
msgstr "użytkownik=\"nazwa użytkownika SQL serwer\""

#: plugins/remote_notifications/templates/remote_notifications_help.html:42
msgid "pass=\"password SQL server\""
msgstr "pass=\"hasło SQL serwera\""

#: plugins/remote_notifications/templates/remote_notifications_help.html:43
msgid "db=\"ospy\" name of table on the SQL server"
msgstr "db=\"ospy\" nazwa tabeli na serwerze SQL"

