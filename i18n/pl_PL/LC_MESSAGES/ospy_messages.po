"\"status\": \"off\", \"name\": \"Station 04\", \"reason\": \"\"}, {\"station"
"\": 4, \"status\": \"off\", \"name\": \"Station 05\", \"reason\": \"\"}, "
"{\"station\": 5, \"status\": \"off\", \"name\": \"Station 06\", \"reason\": "
"\"\"}, {\"station\": 6, \"status\": \"off\", \"name\": \"Station 07\", \"reason"
"\": \"\"}, {\"station\": 7, \"status\": \"off\", \"name\": \"Station 08\", "
"\"reason\": \"\"}]"
msgstr ""
"Przykład wiadomości wychodzącej (główny OSPy): [{\"station\": 0, \"status\": "
"\"off\", \"name\": \"Station 01\", \"reason\": \"\"}, {\"station\": 1, \"status"
"\": \"off\", \"name\": \"Station 02\", \"reason\": \"\"}, {\"station\": 2, "
"\"status\": \"off\", \"name\": \"Station 03\", \"reason\": \"\"}, {\"station"
