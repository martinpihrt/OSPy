msgid "Automatic plug-in updates"
msgstr "Automatické aktualizácie doplnkov"

#: ospy/options.py:127
msgid "Enable plug-in check status updates"
msgstr "Povoliť aktualizácie doplnkov"

#: ospy/options.py:132
msgid "IP for DNS ping"
msgstr "IP pre DNS ping"

#: ospy/options.py:134
msgid ""
"IP address for pinging a DNS server that is outside the internal network. If "
"ping is not available, all network operations (log, user downloads, "
"certificates) are skipped."
msgstr ""
"IP adresa na ping servera DNS, ktorý je mimo internej siete. Ak ping nie je "
"k dispozícii, všetky sieťové operácie (protokol, sťahovanie používateľov, "
"certifikáty) sa vynechajú."

#: ospy/options.py:148
msgid "Use Weather"
