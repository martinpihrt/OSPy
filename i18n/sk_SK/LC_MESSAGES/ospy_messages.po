msgstr ""
"Doplnok Relay 16: 2018-06-06 10:35:08 Nastavenie Relé Výstup relé 22 na HIGH "
"(stanica 1 ON)."

#: plugins/relay_16/templates/relay_16_help.html:43
msgid ""
"Relay 16 plug-in: 2018-06-06 10:35:28 Setings Relay Output 22 to LOW  "
"(Station 1 OFF)."
msgstr ""
"Doplnok Relay 16: 2018-06-06 10:35:28 Nastavenie Relé Výstup relé 22 až "
"NÍZKY (stanica 1 VYPNUTÁ)."

