#: ospy/options.py:151 ospy/options.py:158 ospy/options.py:165
#: plugins/weather_based_rain_delay/__init__.py:78
msgid "Weather"
msgstr "Počasie"

#: ospy/options.py:155
msgid "Storm Glass API key"
msgstr "Kľúč rozhrania API Storm Glass"

#: ospy/options.py:157
msgid ""
"To make use of local weather conditions, a Storm Glass API key is needed."
msgstr ""
"Na využitie miestnych poveternostných podmienok je potrebný kľúč API Storm "
"Glass."

#: ospy/options.py:162
msgid "Location"
msgstr "Poloha"

#: ospy/options.py:164
msgid ""
"City name or zip code. Used to determine location via OpenStreetMap for "
"weather information."
msgstr ""
"Názov mesta alebo PSČ. Používa sa na určenie polohy cez OpenStreetMap pre "
"informácie o počasí."

#: ospy/options.py:171
msgid "Disable security"
msgstr "Zakázať zabezpečenie"

#: ospy/options.py:173
msgid "Allow anonymous users to access the system without a password."
msgstr "Umožniť anonymným používateľom prístup k systému bez hesla."

#: ospy/options.py:174 ospy/options.py:181
msgid "Users"
msgstr "Užívatelia"

#: ospy/options.py:178
msgid "Administrator name"
msgstr "Meno správcu"

#: ospy/options.py:180
msgid "Administrator login name for login to the OSPy."
msgstr "Prihlasovacie meno správcu pre prihlásenie do OSPy."

#: ospy/options.py:187
msgid "Use HTTPS access"
msgstr "Použíť HTTPS"

#: ospy/options.py:189
msgid ""
"Read HELP/Web Interface Guide. SSL certificate via Lets Encrypt "
"certification authority (effective after reboot.)"
msgstr ""
"Prečítajte si Pomocníka/webové rozhranie Guide. SSL certifikát je generovaný "
"prostredníctvom certifikačnej autority (zmeny sa prejavia po reštarte.)"

#: ospy/options.py:190 ospy/options.py:197 ospy/options.py:204
#: ospy/options.py:211 ospy/options.py:218
msgid "Security"
msgstr "Zabezpečenie"

#: ospy/options.py:194
msgid "Domain name"
msgstr "Doménové meno"

#: ospy/options.py:196
msgid ""
"Domain name for generating SSL certificate via Lets Encrypt certification "
"authority. Example: home.sprinkler.com"
msgstr ""
"Názov domény, ktorá bola použitá pre generovanie certifikátu SSL "
"prostredníctvom certifikačnej autority. Príklad: home.sprinkler.com"

#: ospy/options.py:201
msgid "Use Own HTTPS access"
msgstr "Používanie vlastného prístupu HTTPS"

#: ospy/options.py:203
msgid ""
"SSL certificate via own file without certification authority (effective "
"after reboot.)"
msgstr ""
"SSL zabezpečenie pomocou vlastného certifikátu bez certifikačnej autority "
"(po vložení súborov fullchain.pem a privkey.pem do zložky ssl v umiestnení "
"OSPy je nutný reštart OSPy.)"

#: ospy/options.py:208
msgid "API CORS allowed origin"
msgstr "API CORS povolený pôvod"

#: ospy/options.py:210
msgid ""
"Allowed browser origin for API CORS requests. Use * to allow any origin, "
"enter one origin such as https://example.com, enter multiple origins "
"separated by commas, or leave empty to disable CORS headers. This affects "
"browser-based API clients only."
msgstr ""
"Povolený prehliadačový pôvod pre požiadavky API CORS. Použite * na povolenie "
"akéhokoľvek pôvodu, zadajte jeden pôvod, napríklad https://example.com, "
"zadajte viacero pôvodov oddelených čiarkami alebo nechajte prázdne miesto na "
"deaktiváciu CORS hlavičiek. Toto sa týka iba API klientov založených na "
"prehliadači."

#: ospy/options.py:215
msgid "Enable API JSONP"
msgstr "Povoliť API JSONP"

#: ospy/options.py:217
msgid ""
"Allow legacy API JSONP responses via the callback query parameter. Keep "
"disabled unless an old integration requires JSONP, because normal API "
"clients should use JSON with CORS instead."
msgstr ""
"Povoľte staršie odpovede API JSONP prostredníctvom parametra callback "
"dotazu. Nechajte to vypnuté, pokiaľ stará integrácia nevyžaduje JSONP, "
"pretože bežní API klienti by mali používať JSON s CORS namiesto toho."

#: ospy/options.py:224
msgid "Password FW"
msgstr "Heslo FW"

#: ospy/options.py:226
msgid ""
"Password for uploading firmware from OSPy to sensor (for all used sensors - "
"the same password must be used in sensor options.)"
msgstr ""
"Heslo pre nahrávanie firmvéru z OSPy do senzoru (pre všeky použité senzory - "
"rovnaké heslo musí byť použité aj v nastavení senzora). Predvolené heslo je: "
"\"fg4s5b.s,trr7sw8sgyvrDfg\"."

#: ospy/options.py:227 ospy/templates/base.html:287
#: plugins/cli_control/templates/cli_control_help.html:12
#: plugins/email_notifications/__init__.py:226
#: plugins/email_notifications/__init__.py:227
