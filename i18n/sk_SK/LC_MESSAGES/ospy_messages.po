#: plugins/lcd_display/templates/lcd_display_help.html:48
msgid "Sensors"
msgstr "Senzory"

#: ospy/options.py:233
msgid "Maximum usage"
msgstr "Maximálne využitie"

#: ospy/options.py:235
msgid ""
"Determines how station runs are combined. 0 means no limit. 1 means one "
"station at a time when each station has usage 1. This also affects when the "
"pause between stations is inserted."
msgstr ""
"Určuje, ako sa kombinované prevádzky staníc. 0 znamená žiadny limit. 1 "
"znamená jednu stanicu naraz, keď má každá stanica využitie 1. To tiež "
"ovplyvňuje, kedy je vložená pauza medzi stanicami."

#: ospy/options.py:236 ospy/options.py:243 ospy/options.py:252
#: ospy/options.py:261
msgid "Station Handling"
msgstr "Manipulácia so stanicami"

#: ospy/options.py:240
msgid "Number of outputs"
msgstr "Počet výstupov"

#: ospy/options.py:242
msgid "The number of outputs available (8 + 8*extensions)"
msgstr "Počet dostupných výstupov (8 + 8 * rozšírení)"

#: ospy/options.py:249
msgid "Pause between stations"
msgstr "Pauza medzi stanicami"

#: ospy/options.py:251
msgid ""
"Pause inserted between sequential station runs when the scheduler cannot run "
"them at the same time, in seconds between 0 and 3600. This does not shift a "
"station against the master station. Example: with maximum usage 1 and "
"station usage 1, value 30 starts the next station 30 seconds after the "
"previous station ends."
msgstr ""
"Pauza vložená medzi po sebe idúcimi behmi staníc, keď plánovač nedokáže "
"spustiť tieto behy súčasne, v sekundách medzi 0 a 3600. Týmto sa stanica "
"neposúva proti hlavnej stanici. Príklad: pri maximálnom využití 1 a obsadení "
"stanice 1, hodnota 30 začína ďalšiu stanicu 30 sekúnd po skončení "
"predchádzajúcej stanice."

#: ospy/options.py:258
msgid "Minimum runtime"
msgstr "Minimálna doba prevádzky"

#: ospy/options.py:260
msgid ""
"Skip the pause between stations when the previous run was shorter than this "
"value, in seconds between 0 and 86400. Example: with pause 30 and minimum "
"runtime 10, a station that ran only 5 seconds will not force the 30 second "
"pause."
msgstr ""
"Preskočte pauzu medzi stanicami, keď bola predchádzajúca séria kratšia ako "
"táto hodnota, v sekundách medzi 0 a 86400. Príklad: pri pauze 30 a "
"minimálnej dĺžke behu 10 stanica, ktorá bežala len 5 sekúnd, nevynúti 30-"
"sekundovú pauzu."

#: ospy/options.py:269
msgid "Activate relay"
msgstr "Aktivovať relé"

#: ospy/options.py:271
msgid "Also activate the relay as master output."
msgstr "Tiež aktivovať relé ako hlavný výstup."

#: ospy/options.py:272 ospy/options.py:279 ospy/options.py:288
#: ospy/options.py:297 ospy/options.py:306
msgid "Configure Master"
msgstr "Nastavenie hlavnej stanice"

#: ospy/options.py:276
msgid "Master start offset"
msgstr "Posun ?tartu hlavnej stanice"

#: ospy/options.py:278
msgid ""
"Time offset for starting master station 1 relative to the station start, in "
"seconds between -1800 and +1800. Negative values start the master earlier; "
"positive values start it later. Example: -10 starts the master 10 seconds "
"before the station, +10 starts it 10 seconds after the station."
msgstr ""
"Časový posun pre štart hlavnej stanice 1 vzhľadom na štart stanice, v "
"sekundách medzi -1800 a +1800. Záporné hodnoty začínajú master skôr; kladné "
"hodnoty ho začínajú neskôr. Príklad: -10 spustí master 10 sekúnd pred "
"stanicou, +10 10 sekúnd po stanici."

#: ospy/options.py:285
msgid "Master stop offset"
msgstr "Posun vypnutia hlavnej stanice"

#: ospy/options.py:287
msgid ""
"Time offset for stopping master station 1 relative to the station end, in "
"seconds between -1800 and +1800. Negative values stop the master earlier; "
"positive values keep it running longer. Example: -5 stops the master 5 "
"seconds before the station ends, +20 stops it 20 seconds after the station "
"ends."
msgstr ""
"Časový posun pre zastavovaciu hlavnú stanicu 1 vzhľadom na koniec stanice, v "
"sekundách medzi -1800 a +1800. Záporné hodnoty zastavia master skôr; Kladné "
"hodnoty ho udržiavajú v dlhšie. Príklad: -5 zastaví master 5 sekúnd pred "
"koncom stanice, +20 ho zastaví 20 sekúnd po ukončení stanice."

#: ospy/options.py:294
msgid "Master two start offset"
msgstr "Posun ?tartu hlavnej stanice 2"

#: ospy/options.py:296
msgid ""
"Time offset for starting master station 2 relative to the station start, in "
"seconds between -1800 and +1800. Negative values start the master earlier; "
"positive values start it later. Example: -10 starts master 2 10 seconds "
"before the station, +10 starts it 10 seconds after the station."
msgstr ""
"Časový posun pre štart hlavnej stanice 2 vzhľadom na začiatok stanice, v "
"sekundách medzi -1800 a +1800. Záporné hodnoty začínajú master skôr; kladné "
"hodnoty ho začínajú neskôr. Príklad: -10 spustí master 2 10 sekúnd pred "
"stanicou, +10 ju spustí 10 sekúnd po stanici."

#: ospy/options.py:303
msgid "Master two stop offset"
msgstr "Posun vypnutia hlavnej stanice 2"

#: ospy/options.py:305
msgid ""
"Time offset for stopping master station 2 relative to the station end, in "
"seconds between -1800 and +1800. Negative values stop the master earlier; "
"positive values keep it running longer. Example: -5 stops master 2 5 seconds "
"before the station ends, +20 stops it 20 seconds after the station ends."
msgstr ""
"Časový posun pre zastavovaciu hlavnú stanicu 2 vzhľadom na koniec stanice, v "
"sekundách medzi -1800 a +1800. Záporné hodnoty zastavia master skôr; Kladné "
"hodnoty ho udržiavajú v dlhšie. Príklad: -5 zastaví master 2 5 sekúnd pred "
"koncom stanice, +20 ju zastaví 20 sekúnd po ukončení stanice."

