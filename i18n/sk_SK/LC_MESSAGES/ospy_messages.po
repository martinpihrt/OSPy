#: plugins/air_temp_humi/templates/air_temp_humi_help.html:25
msgid ""
"Ultra low cost, 3 to 5V power and I/O, 2.5mA max current use during "
"conversion (while requesting data)."
msgstr ""
"Velmi nízka cena, 3 až 5V napajanie, maximálný prúd 2,5mA počas prevodu (pri "
"vyžiadaní dát)."

#: plugins/air_temp_humi/templates/air_temp_humi_help.html:26
msgid "Good for 20-80% humidity readings with 5% accuracy."
msgstr "Dobré pre vlhkosť 20-80% s 5% toleranciou."

#: plugins/air_temp_humi/templates/air_temp_humi_help.html:27
msgid "Good for 0-50C temperature readings +-2C accuracy."
msgstr "Dobré pre teplotu 0 až 50°C s +-2C toleranciou."

#: plugins/air_temp_humi/templates/air_temp_humi_help.html:28
msgid "No more than 1 Hz sampling rate (once every second)."
msgstr "Vzorkovacia frekvencia max 1Hz raz za sekundu."

#: plugins/air_temp_humi/templates/air_temp_humi_help.html:29
msgid "Body size 15.5mm x 12mm x 5.5mm."
msgstr "Rozmery puzdra 15,5mm x 12mm x 5,5mm."

#: plugins/air_temp_humi/templates/air_temp_humi_help.html:30
#: plugins/air_temp_humi/templates/air_temp_humi_help.html:37
msgid "4 pins with 0.1 inch spacing."
msgstr "4 piny s roztečou 0,1 palca."

#: plugins/air_temp_humi/templates/air_temp_humi_help.html:31
msgid "DHT22/AM2302 (Wired version)"
msgstr "DHT22/AM2302 (káblová verzia)"

#: plugins/air_temp_humi/templates/air_temp_humi_help.html:32
msgid ""
"Low cost, 3 to 5V power and I/O, 2.5mA max current use during conversion "
"(while requesting data)."
msgstr ""
"Nízka cena, 3 až 5V napájanie, maximálny prúd 2,5mA počas prevodu (pri "
"vyžiadaní dát)"

#: plugins/air_temp_humi/templates/air_temp_humi_help.html:33
msgid "Good for 0-100% humidity readings with 2-5% accuracy."
msgstr "Dobré pre vlhkosť 0-100% s 2-5% toleranciou."

#: plugins/air_temp_humi/templates/air_temp_humi_help.html:34
msgid "Good for -40 to 80C temperature readings +-0.5C accuracy."
msgstr "Dobré pre teplotu -40 až 80°C s +-0,5C toleranciou."

#: plugins/air_temp_humi/templates/air_temp_humi_help.html:35
msgid "No more than 0.5 Hz sampling rate (once every 2 seconds)."
msgstr "Vzorkovacia frekvencia max 0,5 Hz raz za 2 sekundy."

#: plugins/air_temp_humi/templates/air_temp_humi_help.html:36
msgid "Body size 15.1mm x 25mm x 7.7mm."
msgstr "Rozmery puzdra 15,1mm x 25mm, 7,7mm."

